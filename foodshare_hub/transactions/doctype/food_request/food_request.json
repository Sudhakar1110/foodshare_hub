      "create": 1,
      "delete": 1
    },
    {
      "role": "FoodShare Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Receiver User",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "track_seen": 1,
  "index_web_pages_for_search": 1
